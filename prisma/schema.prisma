generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}


model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  mobile    String     @unique
  password  String
  photoUrl  String?
  role      String     @default("MEMBER") // MEMBER, ADMIN
  status    String     @default("ACTIVE") // ACTIVE, PENDING
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  donations     Donation[]
  registrations EventRegistration[]
  donationPaymentAttempts DonationPaymentAttempt[]
}

model News {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String   @default("NEWS") // NEWS, CAMPAIGN, RALLY
  isPublished Boolean @default(true)
  imageUrl  String?
  videoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  isOnline    Boolean  @default(false)
  registrationUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  status    String   @default("REGISTERED") // REGISTERED, CANCELLED, ATTENDED
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Donation {
  id          String   @id @default(uuid())
  userId      String?
  amount      Float
  referenceId String
  status      String   @default("SUCCESS") // SUCCESS, FAILED
  paymentMode String   @default("ONLINE") // ONLINE, MANUAL
  gateway     String?
  gatewayOrderId String?
  gatewayPaymentId String?
  gatewaySignature String?
  verifiedAt  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  
  user        User?    @relation(fields: [userId], references: [id])
}

model DonationPaymentAttempt {
  id              String   @id @default(uuid())
  userId          String?
  amount          Float
  currency        String   @default("INR")
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED
  gateway         String   @default("RAZORPAY")
  gatewayOrderId  String   @unique
  gatewayPaymentId String?
  failureReason   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?    @relation(fields: [userId], references: [id])
}
